{
  "name": "nacha-file-parser",
  "displayName": "ACH Syntax Highlighter and Validator",
  "description": "Syntax highlighter and validator for NACHA ACH files",
  "version": "0.0.7",
  "publisher": "RaviRanjan",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rvrn22/nacha-file-parser.git"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:ach"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ach",
        "aliases": [
          "ACH",
          "NACHA"
        ],
        "extensions": [
          ".ach"
        ]
      }
    ],
    "grammars": [
      {
        "language": "ach",
        "scopeName": "source.ach",
        "path": "./syntaxes/ach.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "nacha-file-parser.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "nacha-file-parser.refreshExplorer",
        "title": "Refresh Decoded ACH Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "nacha-file-parser.goToMatchingRecord",
        "title": "ACH: Go to Matching Record"
      },
      {
        "command": "nacha-file-parser.nextProblem",
        "title": "ACH: Go to Next Problem"
      },
      {
        "command": "nacha-file-parser.previousProblem",
        "title": "ACH: Go to Previous Problem"
      },
      {
        "command": "nacha-file-parser.recalculateDerivedFields",
        "title": "ACH: Recalculate All Derived Fields"
      },
      {
        "command": "nacha-file-parser.applyAllSafeFixes",
        "title": "ACH: Apply All Safe Fixes"
      },
      {
        "command": "nacha-file-parser.renumberSequences",
        "title": "ACH: Renumber Batches, Traces, and Addenda Sequences"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "nacha-file-parser.decodedExplorer",
          "name": "Decoded ACH"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "nacha-file-parser.decodedExplorer",
        "contents": "Open a file in ACH language mode to inspect its decoded structure."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "nacha-file-parser.refreshExplorer",
          "when": "view == nacha-file-parser.decodedExplorer",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "nacha-file-parser.goToMatchingRecord",
          "when": "editorLangId == ach",
          "group": "navigation"
        },
        {
          "command": "nacha-file-parser.nextProblem",
          "when": "editorLangId == ach",
          "group": "navigation@10"
        },
        {
          "command": "nacha-file-parser.previousProblem",
          "when": "editorLangId == ach",
          "group": "navigation@11"
        },
        {
          "command": "nacha-file-parser.recalculateDerivedFields",
          "when": "editorLangId == ach",
          "group": "1_modification@10"
        },
        {
          "command": "nacha-file-parser.applyAllSafeFixes",
          "when": "editorLangId == ach",
          "group": "1_modification@11"
        },
        {
          "command": "nacha-file-parser.renumberSequences",
          "when": "editorLangId == ach",
          "group": "1_modification@12"
        }
      ]
    },
    "configuration": {
      "title": "ACH Syntax Highlighter and Validator",
      "properties": {
        "nachaFileParser.validationProfile": {
          "type": "string",
          "enum": [
            "nacha",
            "unblocked"
          ],
          "enumDescriptions": [
            "Require physical records and padding to form complete blocks of 10.",
            "Allow institutions that accept unblocked files while retaining all other validations."
          ],
          "default": "nacha",
          "description": "Controls physical ACH blocking validation."
        },
        "nachaFileParser.maskSensitiveValues": {
          "type": "boolean",
          "default": true,
          "description": "Masks account numbers and individual identifiers in the Decoded ACH explorer."
        },
        "nachaFileParser.showColumnRuler": {
          "type": "boolean",
          "default": true,
          "description": "Shows a vertical boundary at fixed-width ACH column 94."
        },
        "nachaFileParser.showFieldInlayHints": {
          "type": "boolean",
          "default": false,
          "description": "Shows field-name inlay hints at ACH field boundaries."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  }
}
