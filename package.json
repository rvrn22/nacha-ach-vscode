{
  "name": "nacha-file-parser",
  "displayName": "ACH Syntax Highlighter and Validator",
  "description": "Syntax highlighter and validator for NACHA ACH files",
  "version": "0.0.7",
  "publisher": "RaviRanjan",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rvrn22/nacha-file-parser.git"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:ach",
    "onLanguage:plaintext"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "ach-validate": "./bin/ach-validate.js"
  },
  "contributes": {
    "languages": [
      {
        "id": "ach",
        "aliases": [
          "ACH",
          "NACHA"
        ],
        "extensions": [
          ".ach"
        ]
      }
    ],
    "grammars": [
      {
        "language": "ach",
        "scopeName": "source.ach",
        "path": "./syntaxes/ach.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "nacha-file-parser.showFileSummary",
        "title": "ACH: Show File Summary"
      },
      {
        "command": "nacha-file-parser.refreshExplorer",
        "title": "Refresh Decoded ACH Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "nacha-file-parser.goToMatchingRecord",
        "title": "ACH: Go to Matching Record"
      },
      {
        "command": "nacha-file-parser.nextProblem",
        "title": "ACH: Go to Next Problem"
      },
      {
        "command": "nacha-file-parser.previousProblem",
        "title": "ACH: Go to Previous Problem"
      },
      {
        "command": "nacha-file-parser.recalculateDerivedFields",
        "title": "ACH: Recalculate All Derived Fields"
      },
      {
        "command": "nacha-file-parser.applyAllSafeFixes",
        "title": "ACH: Apply All Safe Fixes"
      },
      {
        "command": "nacha-file-parser.renumberSequences",
        "title": "ACH: Renumber Batches, Traces, and Addenda Sequences"
      },
      {
        "command": "nacha-file-parser.exportJsonReport",
        "title": "ACH: Export Redacted JSON Validation Report"
      },
      {
        "command": "nacha-file-parser.exportSarifReport",
        "title": "ACH: Export Redacted SARIF Validation Report"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "nacha-file-parser.decodedExplorer",
          "name": "Decoded ACH"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "nacha-file-parser.decodedExplorer",
        "contents": "Open a file in ACH language mode to inspect its decoded structure."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "nacha-file-parser.refreshExplorer",
          "when": "view == nacha-file-parser.decodedExplorer",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "nacha-file-parser.goToMatchingRecord",
          "when": "editorLangId == ach",
          "group": "navigation"
        },
        {
          "command": "nacha-file-parser.nextProblem",
          "when": "editorLangId == ach",
          "group": "navigation@10"
        },
        {
          "command": "nacha-file-parser.previousProblem",
          "when": "editorLangId == ach",
          "group": "navigation@11"
        },
        {
          "command": "nacha-file-parser.recalculateDerivedFields",
          "when": "editorLangId == ach",
          "group": "1_modification@10"
        },
        {
          "command": "nacha-file-parser.applyAllSafeFixes",
          "when": "editorLangId == ach",
          "group": "1_modification@11"
        },
        {
          "command": "nacha-file-parser.renumberSequences",
          "when": "editorLangId == ach",
          "group": "1_modification@12"
        },
        {
          "command": "nacha-file-parser.exportJsonReport",
          "when": "editorLangId == ach",
          "group": "2_reporting@10"
        },
        {
          "command": "nacha-file-parser.exportSarifReport",
          "when": "editorLangId == ach",
          "group": "2_reporting@11"
        }
      ]
    },
    "configuration": {
      "title": "ACH Syntax Highlighter and Validator",
      "properties": {
        "nachaFileParser.validationProfile": {
          "type": "string",
          "default": "nacha",
          "description": "Named validation profile. Built-ins are 'nacha', 'unblocked', and 'balanced'; custom names can be defined in nachaFileParser.validationProfiles."
        },
        "nachaFileParser.validationProfiles": {
          "type": "object",
          "default": {},
          "description": "Named institution or operator validation profiles.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "extends": {
                "type": "string",
                "enum": ["nacha", "unblocked", "balanced"],
                "default": "nacha"
              },
              "displayName": { "type": "string" },
              "requireBlocking": { "type": "boolean" },
              "validateSecCompatibility": { "type": "boolean" },
              "validateAsciiCharacters": { "type": "boolean" },
              "requireNetZero": { "type": "boolean", "description": "Require calculated file debit and credit totals to net to zero. This checks arithmetic, not the identity of an offset account." },
              "ruleOverrides": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "required": ["severity", "reason"],
                  "properties": {
                    "severity": {
                      "type": "string",
                      "enum": ["error", "warning", "information", "hint", "off"]
                    },
                    "reason": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        },
        "nachaFileParser.ruleOverrides": {
          "type": "object",
          "default": {},
          "description": "Workspace rule severity overrides. Keys may be rule codes, category names such as 'category:physical', or '*'. Every override requires an explanation.",
          "additionalProperties": {
            "type": "object",
            "required": ["severity", "reason"],
            "properties": {
              "severity": {
                "type": "string",
                "enum": ["error", "warning", "information", "hint", "off"]
              },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "nachaFileParser.rowColoring": {
          "type": "string",
          "enum": ["batches", "recordTypes"],
          "default": "batches",
          "description": "Colors rows by alternating batch or by ACH record type."
        },
        "nachaFileParser.recordTypeColors": {
          "type": "object",
          "default": {},
          "description": "Optional background-color overrides for ACH record types.",
          "properties": {
            "1": { "type": "string", "format": "color-hex" },
            "5": { "type": "string", "format": "color-hex" },
            "6": { "type": "string", "format": "color-hex" },
            "7": { "type": "string", "format": "color-hex" },
            "8": { "type": "string", "format": "color-hex" },
            "9": { "type": "string", "format": "color-hex" }
          },
          "additionalProperties": false
        },
        "nachaFileParser.batchRowColors": {
          "type": "array",
          "default": [],
          "minItems": 0,
          "items": { "type": "string", "format": "color-hex" },
          "description": "Optional alternating batch background colors; provide at least two to override the theme defaults."
        },
        "nachaFileParser.fieldColors": {
          "type": "array",
          "default": [],
          "minItems": 0,
          "items": { "type": "string", "format": "color-hex" },
          "description": "Optional alternating field text colors; provide at least two to override the theme defaults."
        },
        "nachaFileParser.paddingRowColor": {
          "type": ["string", "null"],
          "default": null,
          "format": "color-hex",
          "description": "Optional padding-record background color."
        },
        "nachaFileParser.showRecordTypeLabels": {
          "type": "boolean",
          "default": true,
          "description": "Shows textual record-type labels after column 94 so record meaning does not depend on color."
        },
        "nachaFileParser.accessibleFieldBoundaries": {
          "type": "boolean",
          "default": false,
          "description": "Adds dotted underlines to alternating fields; enabled automatically in high-contrast themes."
        },
        "nachaFileParser.maskSensitiveValues": {
          "type": "boolean",
          "default": true,
          "description": "Masks account numbers and individual identifiers in the Decoded ACH explorer."
        },
        "nachaFileParser.showColumnRuler": {
          "type": "boolean",
          "default": true,
          "description": "Shows a vertical boundary at fixed-width ACH column 94."
        },
        "nachaFileParser.showFieldInlayHints": {
          "type": "boolean",
          "default": false,
          "description": "Shows field-name inlay hints at ACH field boundaries."
        },
        "nachaFileParser.detectAchInTextFiles": {
          "type": "boolean",
          "default": true,
          "description": "Detects high-confidence ACH content in .txt files and offers ACH language mode."
        },
        "nachaFileParser.validationDebounceMs": {
          "type": "number",
          "default": 150,
          "minimum": 0,
          "maximum": 2000,
          "description": "Delay before reparsing an actively edited ACH document."
        },
        "nachaFileParser.explorerEntryLimit": {
          "type": "integer",
          "default": 1000,
          "minimum": 0,
          "maximum": 10000,
          "description": "Maximum Entry nodes materialized in the Decoded ACH explorer; totals still include the full file."
        },
        "nachaFileParser.maxDiagnostics": {
          "type": "integer",
          "default": 1000,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum ACH diagnostics shown in VS Code Problems; reports and CLI output remain complete."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "validate:ach": "node ./bin/ach-validate.js",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  }
}
